&CONTROL
  calculation   = 'scf'
  prefix        = 'pwscf'
  outdir        = '/tmp/qe_out'
  pseudo_dir    = '/mnt/d/brahm/agents/vishwakarma/pseudo'
  verbosity     = 'low'
  restart_mode  = 'from_scratch'
/

&SYSTEM
  ibrav         = 0
  nat           = 0
  ntyp          = 0
  ecutwfc       = 40
  ecutrho       = 320
  occupations   = 'smearing'
  smearing      = 'mv'
  degauss       = 0.01
/

&ELECTRONS
  conv_thr        = 1.00e-03
  mixing_beta     = 0.3
  electron_maxstep= 200
/

ATOMIC_SPECIES

ATOMIC_POSITIONS {crystal}

K_POINTS {automatic}
  4 4 4  0 0 0

